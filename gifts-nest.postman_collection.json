    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    try {",
              "        const response = pm.response.json();",
              "",
              "        if (response.data.accessToken) {",
              "            pm.globals.set(\"accessToken\", response.data.accessToken);",
              "        } else {",
              "            console.log(\"Không tìm thấy accessToken trong response.\");",
              "        }",
              "    } catch (e) {",
              "        console.log(\"Lỗi khi xử lý response:\", e);",
              "    }",
              "} else {",
              "    console.log(\"Đăng nhập thất bại, mã lỗi:\", pm.response.code);",
              "}",
              "",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"user\",\n    \"password\": \"abc123\"\n}",
          "options": {
            "raw": {
              "language": "json"
